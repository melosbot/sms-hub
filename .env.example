# ── 设备连接 ──
# 设备 token,与固件 config.h 的 API_TOKEN 一致。
# 设备 IP 无需配置:设备每次 webhook 都会上报自己的地址,hub 自动学习并记住
DEVICE_TOKEN=change-me-please
# 可选:手工指定设备地址(含 token),仅作为初始提示/webhook 不可用时的兜底
#DEVICE_URL=http://192.168.1.100/change-me-please
# 轮询间隔(秒)。webhook 正常时这只是兜底
POLL_INTERVAL=60
# 连续拉取失败 N 次后发 Telegram 失联告警
ALERT_CONSECUTIVE_FAILS=3

# ── 通知通道启动默认值;运行时可在 Web UI 设置页修改 ──
# 推送文案可在设置页按通道配置模板,支持 {sender} {code} {text} 等占位符(详见 README)
# Telegram(留空则不启用)
TG_BOT_TOKEN=
TG_CHAT_ID=
# 大陆直连不通时可填反代地址
TG_API_BASE=https://api.telegram.org
# 是否启用 Telegram 管理命令(/status /sms /history),0=关闭
TG_MANAGE_ENABLED=1

# 短信转发(走设备发短信,留空则不启用)
FORWARD_SMS_TO=
# ── 转发规则 ──
# 可选:管理员手机号。来自该号码的短信不通知;格式 "收件人:内容" 会触发代发
ADMIN_PHONE=
# 黑名单,逗号分隔。完整号码精确匹配;1069 这类短前缀按前缀匹配
BLACKLIST=

# ── 保号 ──
# 每 N 天通过 4G 发起一次极小流量防止 SIM 被回收,0=禁用
KEEPALIVE_INTERVAL_DAYS=0
KEEPALIVE_PING_HOST=119.29.29.29
# 已删除短信墓碑保留天数,防止设备侧旧缓存回流
TOMBSTONE_KEEP_DAYS=30
# 收件箱历史保留天数,0=永久保留
MESSAGE_KEEP_DAYS=0

# ── Web UI ──
WEBUI_USER=admin
WEBUI_PASS=admin123
# 可选:登录令牌签名密钥。留空时 hub 会自动生成并写入 /data/.jwt_secret
JWT_SECRET=
# hub 监听端口
LISTEN_PORT=8025
